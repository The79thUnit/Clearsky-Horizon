# HORIZON local environment
# Copy to .env and adjust for your machine. Do not commit .env.

# Postgres
POSTGRES_USER=horizon
POSTGRES_PASSWORD=changeme_local_only
POSTGRES_DB=horizon
DATABASE_URL=postgresql+asyncpg://horizon:changeme_local_only@postgres:5432/horizon
DATABASE_URL_SYNC=postgresql+psycopg://horizon:changeme_local_only@postgres:5432/horizon

# Redis
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# API
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO
CORS_ALLOW_ORIGINS=http://localhost:5173

# Web
VITE_API_BASE_URL=http://localhost:8000

# Connector defaults
HORIZON_USER_AGENT=HORIZON/0.1 (+https://79thunit.co.uk; 79th Unit OSINT)
HORIZON_DEFAULT_TIMEOUT_SEC=30
HORIZON_DEFAULT_RETRY_MAX=3
HORIZON_DEFAULT_BACKOFF_SEC=5

# Scheduler (Celery Beat intervals, minutes)
CELERY_BEAT_SCHEDULE_PROMED_MINUTES=15
