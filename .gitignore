# ============================================================
# HORIZON — .gitignore
# ============================================================

# --- Secrets / credentials — NEVER commit these ---
.env
.env.production
.env.local
.env.*.local
.env.example
.env.production.example
*.pem
*.key
secrets/

# --- Git meta files (not needed publicly) ---
.gitattributes

# --- Python ---
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg
*.egg-info/
dist/
build/
.eggs/
.installed.cfg
pip-selfcheck.json

# --- Virtual environments ---
.venv/
venv/
env/
ENV/

# --- Testing & coverage ---
.coverage
.coverage.*
coverage.xml
htmlcov/
.pytest_cache/
.mypy_cache/
.ruff_cache/
nosetests.xml
pytest_output.txt

# --- Node / frontend ---
node_modules/
web/dist/
web/build/
web/.vite/

# --- IDE ---
.idea/
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db

# --- Docker local overrides ---
docker-compose.override.yml

# --- Celery ---
celerybeat-schedule
celerybeat.pid

# --- Misc artifacts ---
*.log
*.tmp

# --- Claude Code local files (never push) ---
.claude/
CLAUDE.md

# --- Deploy / bootstrap ephemeral scripts ---
.first_boot_runner.py

# --- Internal files — never push ---
DEPLOYMENT_INSTRUCTIONS.md
DEPLOYMENT_SUMMARY.txt
QUICK_DEPLOY.sh
docs/DEPLOY.md
PROJECT_MANAGEMENT.MD
SIMULATION_REFINEMENT_SUMMARY.md
web/src/data/SIMULATION_REFINEMENT_LOG.md
web/DEPLOY_NOTES.md
web/DEPLOY_NOTES.md

# --- TypeScript build cache & generated artifacts ---
web/tsconfig.node.tsbuildinfo
web/tsconfig.tsbuildinfo
web/vite.config.d.ts
web/vite.config.js

# --- Dev-only test scripts ---
web/test-sim.mjs
web/test-sim-detailed.mjs

# --- Server-specific bootstrap (internal) ---
scripts/server_bootstrap.sh
