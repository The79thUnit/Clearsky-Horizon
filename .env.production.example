# HORIZON production environment template.
#
# Copy to .env.production ON THE SERVER (never commit). Generate strong
# random values for the password and any secret fields:
#
#   openssl rand -hex 32          # for passwords / secrets
#
# .env.production lives at /home/ubuntu/horizon/.env.production
# Permissions: chmod 600 .env.production && chown ubuntu:ubuntu .env.production

# ---------- Postgres ----------
POSTGRES_USER=horizon
POSTGRES_PASSWORD=REPLACE_WITH_openssl_rand_hex_32
POSTGRES_DB=horizon
DATABASE_URL=postgresql://horizon:REPLACE_WITH_SAME_PASSWORD@postgres:5432/horizon
DATABASE_URL_SYNC=postgresql://horizon:REPLACE_WITH_SAME_PASSWORD@postgres:5432/horizon

# ---------- Redis ----------
# Redis now requires authentication. Generate with: openssl rand -hex 24
REDIS_PASSWORD=REPLACE_WITH_openssl_rand_hex_24
REDIS_URL=redis://:REPLACE_WITH_SAME_REDIS_PASSWORD@redis:6379/0
CELERY_BROKER_URL=redis://:REPLACE_WITH_SAME_REDIS_PASSWORD@redis:6379/1
CELERY_RESULT_BACKEND=redis://:REPLACE_WITH_SAME_REDIS_PASSWORD@redis:6379/2

# ---------- API ----------
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO
# Public-facing origins for CORS. Nginx proxies same-origin so these are rarely
# hit, but keep both the canonical apex and the 79thunit branded alias listed
# for any future cross-origin tooling.
CORS_ALLOW_ORIGINS=https://hantavirus.software,https://horizon.79thunit.co.uk
# TrustedHostMiddleware: comma-separated list of allowed Host header values.
# Requests with any other Host header are rejected with HTTP 400.
TRUSTED_HOSTS=hantavirus.software,www.hantavirus.software,horizon.79thunit.co.uk,localhost,127.0.0.1

# ---------- Web build-time ----------
# Vite needs this at build time (baked into the bundle). Empty = same-origin.
VITE_API_BASE_URL=

# ---------- Connector defaults ----------
HORIZON_USER_AGENT=HORIZON/0.1 (+https://hantavirus.software; 79th Unit OSINT)
HORIZON_DEFAULT_TIMEOUT_SEC=30
HORIZON_DEFAULT_RETRY_MAX=3
HORIZON_DEFAULT_BACKOFF_SEC=5

# ---------- Celery beat schedule ----------
CELERY_BEAT_SCHEDULE_PROMED_MINUTES=15

# ---------- TLS ----------
# Email address shown to Let's Encrypt for cert expiry warnings
LETSENCRYPT_EMAIL=director@79thunit.co.uk

# ---------- AIS live vessel tracking ----------
# Primary provider: Kpler (acquired MarineTraffic). Pulled every 2 min by
# the Celery beat schedule via tasks/ais.py::poll_latest_positions.
# Format: base64-encoded "client_id:secret" — paste exactly as supplied
# by Kpler. Sent as `Authorization: Basic <KPLER_API_KEY>`.
KPLER_API_KEY=

# Legacy: aisstream.io websocket daemon (free, community receivers, gappy).
# Kept for reference; the `ais` docker service has been removed. If you
# want to re-enable it, restore the service block in docker-compose and
# set this key.
AISSTREAM_API_KEY=
